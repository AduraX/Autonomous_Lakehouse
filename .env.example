# =============================================================================
# Autonomous Lakehouse Operations Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG

# --- Database (PostgreSQL) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=lakehouse
DATABASE_PASSWORD=lakehouse_dev
DATABASE_NAME=lakehouse
DATABASE_URL=postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# --- Redis (Task Queue) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- Observability ---
OTEL_SERVICE_NAME=autonomous-lakehouse
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090

# --- Platform Adapters ---
# Set PLATFORM_ADAPTER to: mock | adf | fabric | databricks | kubeflow
PLATFORM_ADAPTER=mock

# Azure Data Factory (when PLATFORM_ADAPTER=adf)
# ADF_SUBSCRIPTION_ID=
# ADF_RESOURCE_GROUP=
# ADF_FACTORY_NAME=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Microsoft Fabric (when PLATFORM_ADAPTER=fabric)
# FABRIC_WORKSPACE_ID=
# FABRIC_TENANT_ID=
# FABRIC_CLIENT_ID=
# FABRIC_CLIENT_SECRET=

# Databricks (when PLATFORM_ADAPTER=databricks)
# DATABRICKS_WORKSPACE_URL=https://adb-1234567890.azuredatabricks.net
# DATABRICKS_TOKEN=

# Kubeflow / KF4X (when PLATFORM_ADAPTER=kubeflow)
# KUBEFLOW_HOST=https://kubeflow.example.com
# KUBEFLOW_NAMESPACE=kubeflow-user
# KUBEFLOW_SA_TOKEN=

# --- Iceberg (Data Quality Agent — KF4X Phase 5) ---
# ICEBERG_REST_CATALOG_URL=http://iceberg-rest.iceberg.svc:8181
# ICEBERG_WAREHOUSE=s3://iceberg-warehouse
# ICEBERG_S3_ENDPOINT=http://seaweedfs-s3.seaweedfs.svc:8333
# ICEBERG_S3_ACCESS_KEY=
# ICEBERG_S3_SECRET_KEY=

# --- Keycloak (API Authentication — KF4X Phase 1) ---
# KEYCLOAK_URL=https://keycloak.example.com
# KEYCLOAK_REALM=kubeflow
# KEYCLOAK_CLIENT_ID=lakehouse-ops
# KEYCLOAK_CLIENT_SECRET=

# --- LLM Integration ---
LLM_ENABLED=false
LLM_PROVIDER=claude                          # "claude", "local", "none"
LLM_MODEL=claude-sonnet-4-20250514
LLM_CONFIDENCE_THRESHOLD=0.7                 # Below this, escalate to LLM
# ANTHROPIC_API_KEY=sk-ant-...               # Required when LLM_PROVIDER=claude

# Local LLM (Ollama, vLLM, llama.cpp, LM Studio)
# LLM_LOCAL_URL=http://localhost:11434/v1    # Ollama default
# LLM_LOCAL_MODEL=llama3:8b
# LLM_LOCAL_API_KEY=                         # Optional, some servers need it
